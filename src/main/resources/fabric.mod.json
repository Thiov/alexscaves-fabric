{
  "schemaVersion": 1,
  "id": "alexscaves",
  "version": "${version}",
  "name": "Alex's Caves (Fabric)",
  "description": "Unofficial Fabric port of Alex's Caves for Minecraft 26.1.2. Explore new rare cave biomes hidden under the surface of the Overworld. Original mod by Alexthe668 and Noonyeyz; this Fabric port is maintained by Thiov and is not affiliated with or endorsed by the original authors.",
  "authors": [
    "Alexthe668",
    "Noonyeyz"
  ],
  "contributors": [
    "Thiov (Fabric port)",
    "q4diffuse (Fabric multiversion base)"
  ],
  "contact": {
    "homepage": "https://github.com/Thiov/alexscaves-fabric",
    "sources": "https://github.com/Thiov/alexscaves-fabric",
    "issues": "https://github.com/Thiov/alexscaves-fabric/issues"
  },
  "license": "LGPL-3.0-only",
  "icon": "assets/alexscaves/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.github.alexmodguy.alexscaves.fabric.AlexsCavesFabric"
    ],
    "client": [
      "com.github.alexmodguy.alexscaves.fabric.AlexsCavesFabricClient"
    ],
    "fabric-datagen": [
      "com.github.alexmodguy.alexscaves.fabric.AlexsCavesFabricDataGen"
    ]
  },
  "mixins": [
    "alexscaves.mixins.json"
  ],
  "accessWidener": "alexscaves.accesswidener",
  "depends": {
    "fabricloader": ">=0.19.2",
    "fabric-api": "*",
    "minecraft": "~26.1.2",
    "java": ">=25"
  },
  "suggests": {
    "jei": "*"
  },
  "breaks": {
    "citadel": "*"
  }
}
